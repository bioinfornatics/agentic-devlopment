{
  "hooks": {
    "AfterFileEdit": [
      {
        "matcher": "(\\.agents/(skills|agents)|\\.goose/recipes|evals/.*\\.json)",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/scripts/check-and-regenerate.sh",
            "timeout": 45
          }
        ]
      }
    ]
  }
}
