    {
      "@id": "agent:architect",
      "type": "Agent",
      "name": "architect",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/architect.md",
      "model": "gpt-5.5",
      "description": "Use PROACTIVELY when planning a new feature, making a technology choice, or touching a system boundary. Produces ADRs, design proposals, and trade-off analyses. Read-only.",
      "graph_view": "target"
    },
    {
      "@id": "agent:codebase-researcher",
      "type": "Agent",
      "name": "codebase-researcher",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/codebase-researcher.md",
      "model": "gpt-5.5",
      "description": "Read-only codebase researcher. Use to map architecture, trace blast radius, and gather evidence before planning or implementation. Safe to run in parallel. Produces file-level evidence reports.",
      "graph_view": "target"
    },
    {
      "@id": "agent:harness-judge",
      "type": "Agent",
      "name": "harness-judge",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/harness-judge.md",
      "model": "gpt-5.5",
      "description": "Evidence-first LLM-as-judge for the Goose agentic development harness. Audits completed sessions and harness artifacts across prompt, context, loop, skills, agents, recipes, frameworks, orchestration, ontology/knowledge-graph integrity, and layer-delta value. Invoke for read-only grading and pre-merge harness audits; do not invoke for implementation.",
      "graph_view": "target"
    },
    {
      "@id": "agent:implementation-worker",
      "type": "Agent",
      "name": "implementation-worker",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/implementation-worker.md",
      "model": "gpt-5.5",
      "description": "Implementation specialist for scoped Beads issues. Invoke when a bead is claimed and ready for coding. Enforces TDD (tests first), minimal blast radius, and complete handoff.",
      "graph_view": "target"
    },
    {
      "@id": "agent:orchestrator",
      "type": "Agent",
      "name": "orchestrator",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/orchestrator.md",
      "model": "gpt-5.5",
      "description": "Lead orchestrator for the SDD+TDD loop. Calls load() to discover available specialists and routes to the best match by description. Owns scope partitioning, delegation, and synthesis across all SDD phases. Invoke for work spanning two or more specialist agents or phases.",
      "graph_view": "target"
    },
    {
      "@id": "agent:planner",
      "type": "Agent",
      "name": "planner",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/planner.md",
      "model": "gpt-5.5",
      "description": "Beads dependency graph specialist. Invoked BY product-owner or architect when a product goal requires ordered Beads with dependency chains across more than 5 interdependent issues or multiple files, agents, and sessions.",
      "graph_view": "target"
    },
    {
      "@id": "agent:principal-engineer",
      "type": "Agent",
      "name": "principal-engineer",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/principal-engineer.md",
      "model": "gpt-5.5",
      "description": "Use when a change touches shared infrastructure, public APIs, breaking changes, or architectural boundaries. Escalation path after 2+ BLOCK verdicts from review-critic. Read-only.",
      "graph_view": "target"
    },
    {
      "@id": "agent:product-owner",
      "type": "Agent",
      "name": "product-owner",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/product-owner.md",
      "model": "gpt-5.5",
      "description": "Product Owner \u2014 owns the full backlog lifecycle: user story definition, PRD quality gate (\u226585/100), Beads epic/story creation, priority and assignee management. Invoke at the start of any new feature, for backlog refinement, or to assign work to specialist agents.",
      "graph_view": "target"
    },
    {
      "@id": "agent:qa-automation",
      "type": "Agent",
      "name": "qa-automation",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/qa-automation.md",
      "model": "gpt-5.5",
      "description": "QA automation engineer. Invoked after implementation to design and execute the automated test strategy: unit, integration, E2E. Manages flaky test quarantine, CI integration, and coverage reporting.",
      "graph_view": "target"
    },
    {
      "@id": "agent:review-critic",
      "type": "Agent",
      "name": "review-critic",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/review-critic.md",
      "model": "gpt-5.5",
      "description": "Critical code and Beads handoff reviewer. Invoke after any implementation, before closing a bead or merging. Returns severity-ranked findings with proof and a verdict: APPROVE, PASS-WITH-NITS, or BLOCK.",
      "graph_view": "target"
    },
    {
      "@id": "agent:tdd-guide",
      "type": "Agent",
      "name": "tdd-guide",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/tdd-guide.md",
      "model": "gpt-5.5",
      "description": "Use PROACTIVELY before any new feature implementation or bug fix. Enforces write-tests-first with 80%+ coverage gates. Invoke before implementation-worker to establish the failing RED test first.",
      "graph_view": "target"
    },
    {
      "@id": "agent:ui-designer",
      "type": "Agent",
      "name": "ui-designer",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/ui-designer.md",
      "model": "gpt-5.5",
      "description": "User interface designer. Invoke after UX research validates the direction: for component design, design system consistency, WCAG 2.2 AA compliance, and visual implementation review.",
      "graph_view": "target"
    },
    {
      "@id": "agent:ux-researcher",
      "type": "Agent",
      "name": "ux-researcher",
      "status": "current",
      "source_kind": "explicit",
      "confidence": 1.0,
      "version": "2ab4bc987eb24fd153e50e0b5b39c1a4274d9e5e",
      "updated_at": "2026-07-19T16:55:04.125694+00:00",
      "source_path": ".agents/agents/ux-researcher.md",
      "model": "gpt-5.5",
      "description": "User experience researcher. Invoke when understanding user needs, defining personas, mapping user journeys, planning usability tests, or validating product decisions with user evidence.",
      "graph_view": "target"
    },
